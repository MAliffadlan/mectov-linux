#!/usr/bin/env python3
# ==============================================================================
# Mectov Linux Welcome Application
# Written in Python and PyQt6
# Clean, professional, and dark-themed (Tokyo Night inspired) without emojis
# ==============================================================================

import sys
import os
import subprocess
from PyQt6.QtWidgets import (
    QApplication, QWidget, QVBoxLayout, QHBoxLayout, 
    QPushButton, QLabel, QFrame, QGridLayout
)
from PyQt6.QtCore import Qt, QSize
from PyQt6.QtGui import QFont, QIcon, QPalette, QColor

class WelcomeWindow(QWidget):
    def __init__(self):
        super().__init__()
        self.init_ui()

    def init_ui(self):
        # Set Window Properties
        self.setWindowTitle("Welcome to Mectov Linux")
        self.setFixedSize(680, 420)
        self.setWindowFlags(Qt.WindowType.Window | Qt.WindowType.CustomizeWindowHint | Qt.WindowType.WindowTitleHint | Qt.WindowType.WindowCloseButtonHint)
        
        # Stylesheet (Tokyo Night Theme)
        self.setStyleSheet("""
            QWidget {
                background-color: #1a1b26;
                color: #c0caf5;
                font-family: 'Inter', 'Noto Sans', sans-serif;
            }
            QLabel {
                color: #c0caf5;
            }
            QLabel#title {
                color: #7aa2f7;
                font-size: 28px;
                font-weight: bold;
            }
            QLabel#subtitle {
                color: #565f89;
                font-size: 13px;
                font-weight: 500;
            }
            QLabel#section_title {
                color: #bb9af7;
                font-size: 14px;
                font-weight: bold;
                margin-bottom: 5px;
            }
            QFrame#card {
                background-color: #24283b;
                border: 1px solid #2f3549;
                border-radius: 8px;
            }
            QLabel#info_label {
                font-size: 12px;
                color: #9ece6a;
            }
            QLabel#info_value {
                font-size: 12px;
                color: #c0caf5;
                font-weight: bold;
            }
            QPushButton {
                background-color: #24283b;
                border: 1px solid #3b4261;
                border-radius: 6px;
                color: #c0caf5;
                padding: 12px;
                font-size: 13px;
                font-weight: bold;
                text-align: left;
            }
            QPushButton:hover {
                background-color: #2f3549;
                border: 1px solid #7aa2f7;
            }
            QPushButton#action_install {
                background-color: #7aa2f7;
                border: 1px solid #7aa2f7;
                color: #15161e;
            }
            QPushButton#action_install:hover {
                background-color: #89ddff;
                border: 1px solid #89ddff;
            }
        """)

        # Main Layout
        main_layout = QVBoxLayout()
        main_layout.setContentsMargins(30, 30, 30, 30)
        main_layout.setSpacing(25)

        # Header Section
        header_layout = QVBoxLayout()
        header_layout.setSpacing(5)
        
        title_label = QLabel("Mectov Linux")
        title_label.setObjectName("title")
        
        subtitle_label = QLabel("An Arch-based distribution with KDE Plasma desktop environment")
        subtitle_label.setObjectName("subtitle")
        
        header_layout.addWidget(title_label)
        header_layout.addWidget(subtitle_label)
        main_layout.addLayout(header_layout)

        # Content Section (Split into Info Card and Action Buttons)
        content_layout = QHBoxLayout()
        content_layout.setSpacing(20)

        # Left Column: Info Card
        info_card = QFrame()
        info_card.setObjectName("card")
        info_card_layout = QVBoxLayout(info_card)
        info_card_layout.setContentsMargins(20, 20, 20, 20)
        info_card_layout.setSpacing(15)

        info_title = QLabel("System Information")
        info_title.setObjectName("section_title")
        info_card_layout.addWidget(info_title)

        # Grid for specs
        spec_grid = QGridLayout()
        spec_grid.setSpacing(10)
        
        specs = [
            ("Base System", "Arch Linux"),
            ("Desktop", "KDE Plasma 6"),
            ("Display Server", "Wayland"),
            ("Audio Server", "PipeWire"),
            ("Default Shell", "Fish")
        ]

        for i, (label, val) in enumerate(specs):
            lbl = QLabel(label)
            lbl.setObjectName("info_label")
            v = QLabel(val)
            v.setObjectName("info_value")
            spec_grid.addWidget(lbl, i, 0)
            spec_grid.addWidget(v, i, 1)

        info_card_layout.addLayout(spec_grid)
        info_card_layout.addStretch()
        content_layout.addWidget(info_card, stretch=1)

        # Right Column: Action Buttons
        button_layout = QVBoxLayout()
        button_layout.setSpacing(12)

        install_btn = QPushButton("Launch Installer")
        install_btn.setObjectName("action_install")
        install_btn.clicked.connect(self.launch_installer)

        browser_btn = QPushButton("Open Web Browser")
        browser_btn.clicked.connect(self.launch_browser)

        terminal_btn = QPushButton("Open Terminal")
        terminal_btn.clicked.connect(self.launch_terminal)

        github_btn = QPushButton("View Repository")
        github_btn.clicked.connect(self.open_github)

        quit_btn = QPushButton("Close")
        quit_btn.setStyleSheet("color: #f7768e; border: 1px solid #f7768e;")
        quit_btn.clicked.connect(self.close)

        button_layout.addWidget(install_btn)
        button_layout.addWidget(browser_btn)
        button_layout.addWidget(terminal_btn)
        button_layout.addWidget(github_btn)
        button_layout.addWidget(quit_btn)
        button_layout.addStretch()

        content_layout.addLayout(button_layout, stretch=1)
        main_layout.addLayout(content_layout)

        self.setLayout(main_layout)
        self.center_on_screen()

    def center_on_screen(self):
        screen = QApplication.primaryScreen().geometry()
        size = self.geometry()
        self.move(int((screen.width() - size.width()) / 2), int((screen.height() - size.height()) / 2))

    def launch_installer(self):
        subprocess.Popen(["mectov-install"])
        self.close()

    def launch_browser(self):
        subprocess.Popen(["firefox"])

    def launch_terminal(self):
        subprocess.Popen(["konsole"])

    def open_github(self):
        subprocess.Popen(["firefox", "https://github.com/mectov/mectov-linux"])

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = WelcomeWindow()
    window.show()
    sys.exit(app.exec())
